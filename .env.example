BOT_TOKEN=your_telegram_bot_token_here
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/studyhub
ADMIN_ID=your_telegram_user_id

# Set to "production" only on Render. Any other value (or unset) runs the bot
# locally with long-polling instead of webhooks.
NODE_ENV=development
PORT=10000
WEBHOOK_URL=https://your-app.onrender.com

# GramJS user account (used to read channels the bot itself can't access)
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_SESSION=your_string_session

# Private group/channel IDs used by the archive + relay delivery pipeline
RELAY_GROUP_ID=your_relay_group_chat_id
ARCHIVE_CHAT_ID=your_archive_channel_chat_id

# Set to "true" to disable the cron-based channel indexer (useful for local testing)
DISABLE_AUTO_INDEX=false